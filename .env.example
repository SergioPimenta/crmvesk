# Frontend — em produção na Vercel deixe vazio para usar /api no mesmo domínio
# VITE_API_URL=/api

POSTGRES_URL=postgresql://user:pass@host/db?sslmode=require
JWT_SECRET=sua_chave_secreta_aqui

# URL pública do CRM (Evolution registra webhook aqui)
WHATSAPP_WEBHOOK_PUBLIC_URL=https://seu-app.vercel.app

# Scraping Google Maps (gratuito) — serviço Python Playwright
# Local: npm run scraper  →  MAPS_SCRAPER_URL=http://localhost:8765
MAPS_SCRAPER_URL=

# Opcional: API paga do Google (só se MAPS_SCRAPER_URL não estiver configurado)
GOOGLE_MAPS_API_KEY=
