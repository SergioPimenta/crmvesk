{
  "name": "crmvesk",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "scraper": "python -m uvicorn main:app --app-dir scraper --host 0.0.0.0 --port 8765",
    "scraper:install": "pip install -r scraper/requirements.txt && playwright install chromium",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "vercel:login": "npx --yes vercel@latest login",
    "vercel:link": "npx --yes vercel@latest link",
    "vercel:setup": "node scripts/vercel-setup.mjs",
    "vercel:deploy": "npx --yes vercel@latest deploy --prod"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@tailwindcss/vite": "^4.0.0",
    "@vercel/blob": "^0.27.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.300.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
